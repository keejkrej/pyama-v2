{
  "name": "pyama-v2",
  "private": true,
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/pyama"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:pyama": "turbo run build --filter=pyama",
    "dev:pyama": "turbo run dev --filter=pyama",
    "dev:pyama-server": "turbo run dev:server --filter=pyama",
    "dev:pyama-web": "turbo run dev:web --filter=pyama",
    "release:pyama": "turbo run release --filter=pyama",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check:tauri": "turbo run check:tauri",
    "check:rust": "cargo check --workspace",
    "check": "bun run typecheck && bun run check:rust"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
