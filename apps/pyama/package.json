{
  "name": "pyama",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite --config vite.config.ts",
    "dev:server": "cargo watch -q -c -C src-tauri -x \"run -- server --lan\"",
    "dev": "bunx @tauri-apps/cli dev",
    "build": "tsc --noEmit -p tsconfig.json && vite build --config vite.config.ts",
    "release": "bun ./scripts/release.mjs",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "check:tauri": "cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.168.25",
    "class-variance-authority": "^0.7.1",
    "effect": "^3.21.0",
    "lucide-react": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "shadcn": "^4.13.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.28",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "^1.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.3",
    "vite": "^6.3.0"
  }
}
