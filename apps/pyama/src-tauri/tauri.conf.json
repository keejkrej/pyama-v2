{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pyama",
  "version": "0.2.0",
  "identifier": "com.pyama.app",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pyama",
        "width": 1280,
        "height": 720,
        "minWidth": 1280,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
"icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
