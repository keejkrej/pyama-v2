{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "allow-scan-source",
    "allow-load-frame",
    "allow-list-saved-bbox-positions",
    "allow-load-align-state",
    "allow-auto-exclude-preview",
    "allow-save-bbox",
    "allow-list-directory",
    "allow-user-home-directory",
    "allow-read-text-file"
  ]
}
