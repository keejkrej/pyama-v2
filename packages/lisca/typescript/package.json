{
  "name": "lisca",
  "version": "0.2.0",
  "description": "TypeScript pipeline layer for LISCA viewer contracts, UI, and host integration.",
  "packageManager": "bun@1.2.22",
  "type": "module",
  "exports": {
    "./shared/query": "./src/shared/query/index.ts",
    "./shared/contracts": "./src/shared/contracts/index.ts",
    "./shared/core": "./src/shared/core/index.ts",
    "./shared/host": "./src/shared/host/index.ts",
    "./shared/react": "./src/shared/react/index.ts",
    "./shared/react/align": "./src/shared/react/align/index.ts",
    "./shared/state": "./src/shared/state/index.ts",
    "./shared/ui": "./src/shared/ui/index.ts",
    "./shared/ui/theme.css": "./src/shared/ui/theme.css",
    "./viewer/host": "./src/viewer/host/index.ts",
    "./viewer/react": "./src/viewer/react/index.ts",
    "./viewer/styles.css": "./src/viewer/react/app/viewer.css"
  },
  "files": [
    "src",
    "test",
    "README.md",
    "tsconfig.base.json",
    "tsconfig.json"
  ],
  "sideEffects": [
    "./src/viewer/react/app/viewer.css",
    "./src/shared/ui/theme.css"
  ],
  "scripts": {
    "check": "bun run typecheck",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.0",
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "effect": "^3.21.0",
    "lucide-react": "^1.6.0",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.3.0"
  }
}
